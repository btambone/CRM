# Copy this file to .env and fill in your own values to enable email campaigns.
# Get a free Resend account and API key at https://resend.com

RESEND_API_KEY=
EMAIL_FROM=you@yourdomain.com
EMAIL_FROM_NAME=Inflate AI

# Optional: enables the {{home_value}} field in campaigns and the "Get Home
# Value" button on a contact's profile. Get an API key at https://rentcast.io
# (has a small free tier; paid per lookup beyond that, roughly $0.10-0.20 each).
RENTCAST_API_KEY=
